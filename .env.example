# ─── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google / Gemini ─────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─── Instagram / Meta ────────────────────────────────────────────────────────
# Long-lived access token (60-day). Stored also in Supabase api_tokens table.
IG_ACCESS_TOKEN=IGQW...
# Instagram Business Account ID (numeric)
IG_BUSINESS_ACCOUNT_ID=17841...
# Instagram handle (no @)
IG_ACCOUNT=keithjskaggs

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=abc123...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=reels-media
# Public base URL for R2 bucket — MUST be a public HTTPS endpoint (IG Graph API
# rejects signed URLs and private-access URLs for Reels video_url). Configure
# a custom domain on the R2 bucket (e.g. media.1commerce.online) with public
# access enabled, and set that domain here.
R2_PUBLIC_BASE_URL=https://media.1commerce.online

# ─── Submagic ────────────────────────────────────────────────────────────────
SUBMAGIC_API_KEY=...

# ─── Google Drive ────────────────────────────────────────────────────────────
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Drive folder ID for reels-inbox (from folder URL)
GDRIVE_INBOX_FOLDER_ID=1AbC...

# ─── Notifications ───────────────────────────────────────────────────────────
# Discord or Slack webhook URL for alerts
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── n8n Internal ────────────────────────────────────────────────────────────
# Webhook URL for n8n workflow 04 (auto-edit). After importing
# 04-auto-edit-submagic.json, open the workflow in n8n, click the Webhook
# Trigger node, copy the Production URL, and paste it here.
N8N_WEBHOOK_URL_04_EDIT=https://your-n8n-host/webhook/04-auto-edit

# ─── Cost Guards ─────────────────────────────────────────────────────────────
# Max Veo B-roll generations per calendar month
VEO_MONTHLY_LIMIT=25
